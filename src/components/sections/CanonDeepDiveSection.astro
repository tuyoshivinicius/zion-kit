---
import SectionHeader from '../ui/SectionHeader.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';

const businessLayer = [
  { name: 'Glossário de linguagem ubíqua', desc: 'O dicionário oficial do produto. Cada termo tem uma definição precisa, acordada por todos.' },
  { name: 'Regras de negócio', desc: 'Restrições e políticas do produto, expressas de forma clara e verificável.' },
  { name: 'Requisitos formalizados', desc: 'Requisitos produzidos via mediação da IA — linguagem natural traduzida para formato preciso.' },
  { name: 'Fluxos de domínio', desc: 'O que acontece, em que ordem, quem faz o quê — derivados das sessões de descoberta.' },
];

const archLayer = [
  { name: 'Princípios técnicos constitucionais', desc: 'Stack, comunicação entre componentes, segurança, observabilidade.' },
  { name: 'Bounded contexts', desc: 'Fronteiras lógicas que separam áreas com vocabulário e regras próprias.' },
  { name: 'Eventos de domínio', desc: 'Catálogo dos fatos relevantes que acontecem no sistema, com dados e consumidores.' },
  { name: 'Context maps', desc: 'Como as áreas do negócio se relacionam entre si e trocam informações.' },
  { name: 'ADRs', desc: 'O que foi decidido, por quê, quais alternativas foram consideradas e consequências.' },
];
---

<section id="canon" class="canon-section section-even">
  <div class="max-width-content">
    <ScrollReveal animation="fade-up">
      <SectionHeader
        sectionNumber={8}
        title='Anatomia da <span class="gradient-text">Product Canon</span>'
        depth={3}
        subtitle="A Product Canon é um conjunto de documentos versionados que representam o conhecimento do produto em duas camadas complementares."
      />
    </ScrollReveal>

    <div class="canon-columns">
      <ScrollReveal animation="slide-left">
        <div class="canon-column business">
          <h3 class="column-title">
            <span class="column-dot business-dot" aria-hidden="true"></span>
            Camada de Negócio
          </h3>
          <p class="column-desc">Legível por pessoas não-técnicas</p>
          <div class="canon-cards">
            {businessLayer.map(item => (
              <div class="canon-card">
                <h4>{item.name}</h4>
                <p>{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal animation="slide-right">
        <div class="canon-column architecture">
          <h3 class="column-title">
            <span class="column-dot arch-dot" aria-hidden="true"></span>
            Camada de Arquitetura
          </h3>
          <p class="column-desc">Decisões técnicas e estruturais</p>
          <div class="canon-cards">
            {archLayer.map(item => (
              <div class="canon-card">
                <h4>{item.name}</h4>
                <p>{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </ScrollReveal>
    </div>

    <ScrollReveal animation="fade-up" delay={0.3}>
      <p class="canon-footnote">
        Todos os artefatos são documentos markdown versionados em Git — com rastreabilidade completa de quem alterou o quê, quando e por quê.
      </p>
    </ScrollReveal>
  </div>
</section>

<style>
  .canon-section {
    padding: var(--space-24) 0;
    background-color: var(--color-bg-secondary);
  }

  .canon-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 768px) {
    .canon-columns {
      grid-template-columns: 1fr;
    }
  }

  .canon-column {
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .canon-column.business {
    border-color: rgba(52, 211, 153, 0.2);
  }

  .canon-column.architecture {
    border-color: rgba(167, 139, 250, 0.2);
  }

  .column-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .column-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .business-dot { background: var(--color-aurora-green); }
  .arch-dot { background: var(--color-aurora-violet); }

  .column-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .canon-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .canon-card {
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .canon-card h4 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .canon-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .canon-footnote {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-6);
  }
</style>
