---
import SectionHeader from '../ui/SectionHeader.astro';
import DiagramContainer from '../ui/DiagramContainer.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';
import CycleDiagram from '../diagrams/CycleDiagram';

const steps = [
  { icon: '🔨', title: 'Etapa 1 — Canon Building', desc: 'Pessoas de negócio e tecnologia constroem a Product Canon através de 3 cerimônias formais — Domain Discovery Session, Technical Constitution Session e Requirements Specification Session — com gates de aprovação entre cada uma. Ao final, a Decisão de Continuidade do Ciclo oferece 3 caminhos: mapear mais fluxos, formalizar mais requisitos ou encerrar e prosseguir para a especificação.' },
  { icon: '📝', title: 'Etapa 2 — Spec Crafting', desc: 'Quando alguém escreve uma especificação de feature, a IA consulta a Product Canon e carrega o contexto relevante. Se a especificação revela impactos não antecipados no Canon Building, a IA gera um Canonical Change Plan incremental (incremental-plan), aprovado condicionalmente por camada afetada antes que qualquer código seja escrito.' },
  { icon: '🔄', title: 'Etapa 3 — Canon Enrichment', desc: 'Depois da implementação, descobertas emergentes retornam à Product Canon. O desenvolvedor sinaliza explicitamente achados no código (CANON-DISCOVERY), e a IA complementa com detecção assistida — comparando artefatos produzidos contra a Product Canon para identificar conceitos não formalizados.' },
];
---

<section id="ciclo" class="cycle-section section-even" aria-labelledby="heading-ciclo">
  <div class="max-width-content">
    <ScrollReveal animation="fade-up">
      <SectionHeader
        sectionNumber={4}
        sectionId="ciclo"
        title='Como o ciclo de <span class="gradient-text">três etapas funciona</span>'
        depth={1}
        subtitle="O ZionKit opera em um ciclo bidirecional de três etapas: informação flui da Product Canon para as especificações e das especificações de volta para a Product Canon. A cada volta, o repositório de conhecimento fica mais rico. Além do ciclo formal, o Domain Expert pode editar diretamente artefatos da camada de negócio como canal complementar de manutenção."
      />
    </ScrollReveal>

    <ScrollReveal animation="scale-in">
      <DiagramContainer label="O Ciclo ZionKit — três etapas que se repetem continuamente" title="Diagrama 3 — O Ciclo ZionKit">
        <CycleDiagram client:visible />
      </DiagramContainer>
    </ScrollReveal>

    <ScrollReveal animation="stagger">
      <div class="steps-grid">
        {steps.map(step => (
          <div class="step-card">
            <span class="step-icon" aria-hidden="true">{step.icon}</span>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  .cycle-section {
    padding: var(--space-24) 0;
    background-color: var(--color-bg-secondary);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }

  .step-card {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    transition: border-color var(--duration-normal) ease, box-shadow var(--duration-normal) ease;
  }

  .step-card:hover {
    border-color: var(--color-border-accent);
    box-shadow: var(--shadow-glow-cyan);
  }

  .step-icon {
    font-size: var(--text-3xl);
    display: block;
    margin-bottom: var(--space-3);
  }

  .step-card h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .step-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
