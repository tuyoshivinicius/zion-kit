---
import SectionHeader from '../ui/SectionHeader.astro';
import GlossaryItem from '../ui/GlossaryItem.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';

const glossaryTerms = [
  {
    id: 'product-canon',
    term: 'Product Canon',
    definition: 'Repositório central e versionado onde todo o conhecimento do produto fica formalizado — regras, vocabulário, processos, decisões técnicas.',
    analogy: 'A constituição do produto: todo mundo segue as mesmas regras, e quando algo muda, existe um processo formal.',
  },
  {
    id: 'canon-building',
    term: 'Canon Building',
    definition: 'Processo de construir e manter a Product Canon, composto por três sessões formais com aprovação entre cada uma.',
    analogy: 'Montar a enciclopédia do produto — sessão por sessão, com revisão antes de publicar cada capítulo.',
  },
  {
    id: 'canonical-change-plan',
    term: 'Canonical Change Plan',
    definition: 'Documento que descreve exatamente o que será adicionado ou alterado na Product Canon. Possui envelope com metadados (tipo, status, autor, escopo) e payload com conteúdo da mudança. Precisa de aprovação.',
    analogy: 'A proposta de emenda à constituição do produto — descreve o que muda, quem precisa aprovar, e só entra em vigor depois da votação.',
  },
  {
    id: 'domain-builder',
    term: 'Domain Builder',
    definition: 'Pessoa de negócio (PO, analista, gestor) que conhece o produto e descreve processos e requisitos em linguagem natural.',
    analogy: 'O morador da casa — sabe como quer viver nela, mesmo sem ser engenheiro civil.',
  },
  {
    id: 'architect',
    term: 'Architect',
    definition: 'Pessoa técnica que define as regras de arquitetura e valida viabilidade.',
    analogy: 'O engenheiro estrutural — garante que o prédio fica de pé.',
  },
  {
    id: 'domain-expert',
    term: 'Domain Expert',
    definition: 'Autoridade sobre o significado dos conceitos do negócio. Aprova que o conhecimento registrado é fiel à realidade.',
    analogy: 'O revisor técnico da enciclopédia — garante que o que está escrito é verdade.',
  },
  {
    id: 'bounded-context',
    term: 'Bounded Context',
    definition: 'Área delimitada do negócio com vocabulário e regras próprias. "Pagamentos" e "Notificações" são contextos diferentes.',
    analogy: 'Departamentos de uma empresa — cada um tem sua linguagem e suas regras, mesmo fazendo parte do mesmo negócio.',
  },
  {
    id: 'linguagem-ubiqua',
    term: 'Linguagem Ubíqua',
    definition: 'Vocabulário oficial do produto onde cada palavra tem um significado acordado por todos.',
    analogy: 'O dicionário da empresa — quando alguém diz "cliente inativo", todo mundo entende a mesma coisa.',
  },
  {
    id: 'event-storming',
    term: 'Event Storming',
    definition: 'Técnica colaborativa de mapeamento de processos. No ZionKit, é feita via conversa com a IA em vez de post-its em uma parede.',
    analogy: 'Contar a história do negócio do começo ao fim, e alguém organiza em um mapa enquanto você fala.',
  },
  {
    id: 'sbvr',
    term: 'SBVR',
    definition: 'Método para escrever regras de negócio de forma precisa mas legível. No ZionKit, a IA faz a tradução — o Domain Builder fala normal e valida o resultado.',
    analogy: 'Traduzir "o cliente pode cancelar antes de pagar" para "É obrigatório que Pedidos com status \'Pendente\' possam ser cancelados pelo titular" — preciso, mas compreensível.',
  },
  {
    id: 'sbe',
    term: 'SBE (Specification by Example)',
    definition: 'Técnica que usa exemplos concretos como critérios de aceitação. Em vez de "o sistema deve validar o pagamento", diz "Dado um pagamento de R$ 100 via PIX, quando confirmado, então o saldo é debitado em R$ 100."',
    analogy: 'Explicar uma regra mostrando casos — como explicar um jogo mostrando jogadas.',
  },
  {
    id: 'adr',
    term: 'ADR (Architecture Decision Record)',
    definition: 'Registro formal de uma decisão técnica: o que foi decidido, por quê, quais alternativas existiam e quais são as consequências.',
    analogy: 'A ata de uma decisão importante — para que ninguém precise perguntar "por que fizemos assim?" daqui a 6 meses.',
  },
  {
    id: 'strangler-fig',
    term: 'Strangler Fig (Versionamento Gradual)',
    definition: 'Padrão para aplicar mudanças grandes de forma gradual. A versão nova cresce ao redor da antiga até substituí-la completamente.',
    analogy: 'Reformar uma casa morando nela — um cômodo por vez, sem precisar mudar para outro lugar.',
  },
  {
    id: 'guardrails',
    term: 'Guardrails de Conformidade',
    definition: 'Mecanismos automáticos da IA que identificam quando alguém usa um termo diferente do vocabulário oficial ou propõe algo que contradiz regras existentes.',
    analogy: 'O corretor ortográfico do produto — se você escreve "cliente" onde o vocabulário define "titular da conta", ele sinaliza.',
  },
  {
    id: 'injecao-seletiva',
    term: 'Injeção Seletiva de Contexto',
    definition: 'A IA não recebe toda a Product Canon de uma vez — apenas os fragmentos relevantes para a tarefa atual.',
    analogy: 'Levar para a reunião só os documentos que importam para aquele assunto, não o arquivo inteiro.',
  },
  {
    id: 'retroalimentacao',
    term: 'Retroalimentação',
    definition: 'Processo de devolver à Product Canon as descobertas feitas durante a implementação.',
    analogy: 'Atualizar o manual depois de montar o móvel, incluindo os passos que estavam faltando.',
  },
  {
    id: 'envelope-change-plan',
    term: 'Envelope do Change Plan',
    definition: 'Conjunto de metadados que acompanha todo Canonical Change Plan: identificador, tipo, status, autor, escopo e registro de aprovações.',
    analogy: 'A capa de um processo administrativo — identifica o processo, seu status e quem já assinou.',
  },
  {
    id: 'expert-edit-plan',
    term: 'expert-edit-plan',
    definition: 'Tipo de Canonical Change Plan originado por edição direta do Domain Expert. Aprovação sequencial obrigatória: Domain Expert valida fidelidade, Architect avalia impacto técnico.',
    analogy: 'Uma correção no manual do produto — o especialista propõe, mas o engenheiro precisa verificar se a mudança não quebra nada.',
  },
  {
    id: 'incremental-plan',
    term: 'incremental-plan',
    definition: 'Tipo de Canonical Change Plan gerado na Etapa 2 (Spec Crafting). Captura impactos emergentes que só aparecem quando uma spec concreta é escrita contra a Product Canon. Pode ser vazio (sem impacto = sem aprovação).',
    analogy: 'A lista de ajustes que aparece quando você aplica uma regra geral a um caso concreto.',
  },
  {
    id: 'protocolo-perspectiva-assistida',
    term: 'Protocolo de Perspectiva Assistida',
    definition: 'Mecanismo que permite que uma mesma pessoa exerça múltiplos papéis sem perder a qualidade das validações. A IA apresenta perguntas específicas da perspectiva de cada papel.',
    analogy: 'Quando o fundador de uma startup precisa ser ao mesmo tempo o cliente e o vendedor — ele usa um checklist diferente para cada "chapéu".',
  },
  {
    id: 'hotspot-dominio',
    term: 'Hotspot de domínio',
    definition: 'Área da Product Canon marcada pelo Domain Expert como frágil, frequentemente mal interpretada, ou com histórico de problemas. A IA usa essas marcações para atenção especial durante validações.',
    analogy: 'Um trecho de uma receita com a anotação "cuidado aqui — já errei várias vezes nesse passo".',
  },
  {
    id: 'anotacao-contextual',
    term: 'Anotação contextual',
    definition: 'Observação que o Domain Expert adiciona durante a revisão de um Change Plan — nuances de domínio, ressalvas, esclarecimentos. Ciclo de vida: formalizar, descartar ou adiar.',
    analogy: 'Um post-it na margem de um documento — "isso aqui merece uma discussão mais profunda depois".',
  },
  {
    id: 'relatorio-conformidade',
    term: 'Relatório de Conformidade',
    definition: 'Documento gerado pela IA durante edição direta. 4 seções: divergências terminológicas, contradições com regras, impactos em bounded contexts, divergências intencionais aceitas.',
    analogy: 'O parecer do revisor antes de publicar — lista tudo que encontrou de inconsistente para o autor decidir.',
  },
  {
    id: 'aprovacao-afinidade',
    term: 'Aprovação por afinidade',
    definition: 'Modelo de aprovação onde o aprovador primário é o papel com expertise principal. O secundário opera com janela de veto assíncrona — sem manifestação no prazo = aprovação tácita.',
    analogy: 'Quem entende de encanamento aprova a obra de encanamento; o síndico pode vetar, mas se não disser nada no prazo, a obra segue.',
  },
  {
    id: 'sinalizacao-explicita',
    term: 'Sinalização explícita',
    definition: 'Marcação durante implementação para registrar descobertas emergentes (ex.: // CANON-DISCOVERY: conceito novo). Captura aprendizados no momento em que surgem.',
    analogy: 'Anotar no cantinho do caderno "lembrar de incluir isso no relatório" enquanto trabalha.',
  },
  {
    id: 'deteccao-assistida',
    term: 'Detecção assistida',
    definition: 'IA compara código implementado contra Product Canon e identifica conceitos novos não sinalizados. Rede de segurança.',
    analogy: 'O revisor que lê o texto final e percebe uma referência nova que o autor esqueceu de adicionar ao índice.',
  },
  {
    id: 'clarificacao-conformidade',
    term: 'Clarificação de Conformidade',
    definition: 'Guardrail que sinaliza quando alguém usa termos diferentes do vocabulário oficial. Não bloqueia — pergunta e propõe alinhamento.',
    analogy: 'O corretor ortográfico do produto — sublinha e pergunta.',
  },
  {
    id: 'validacao-consistencia',
    term: 'Validação de Consistência',
    definition: 'Guardrail que confronta alterações com estado atual da Product Canon, detectando contradições em ambas as camadas.',
    analogy: 'O verificador de compatibilidade — antes de instalar uma peça nova, confere se não conflita.',
  },
  {
    id: 'validacao-semantica-interna',
    term: 'Validação Semântica Interna',
    definition: 'Guardrail interno da IA (incluindo SBVR) para detectar ambiguidade, incompletude e contradição. Resultados em linguagem natural.',
    analogy: 'O consultor que lê nas entrelinhas e transforma em perguntas claras.',
  },
  {
    id: 'padronizacao-canonica',
    term: 'Padronização Canônica',
    definition: 'Guardrail que garante formato IEEE 29148 + SBE em toda escrita na Product Canon. Reescreve automaticamente.',
    analogy: 'O formatador de documentos — você escreve o conteúdo, ele coloca nos campos certos.',
  },
  {
    id: 'nivel-aderencia-ieee',
    term: 'Nível de aderência IEEE 29148',
    definition: 'Configuração de formalidade dos requisitos: Mínimo (tipo + descrição + SBE), Moderado (+ rastreabilidade e dependências), Completo (aplicação integral). Definido pelo Architect.',
    analogy: 'O nível de detalhe de uma planta de casa — croqui básico, planta técnica ou projeto executivo.',
  },
  {
    id: 'decisao-continuidade',
    term: 'Decisão de Continuidade',
    definition: 'Ponto de decisão no final de cada ciclo de Canon Building. 3 caminhos: mapear mais fluxos, formalizar mais requisitos, ou encerrar e seguir para Spec Crafting.',
    analogy: 'O final de cada capítulo de um livro — o autor decide se continua a história, aprofunda um ponto, ou passa para o próximo ato.',
  },
];
---

<section id="glossario" class="glossary-section section-even" aria-labelledby="heading-glossario">
  <div class="max-width-content">
    <ScrollReveal animation="fade-up">
      <SectionHeader
        sectionNumber={16}
        sectionId="glossario"
        title='Glossário <span class="gradient-text">acessível</span>'
        subtitle="Referência rápida para qualquer conceito mencionado neste site."
        depth={1}
      />
    </ScrollReveal>

    <ScrollReveal animation="fade-up" delay={0.15}>
      <search class="glossary-search">
        <label for="glossary-filter" class="sr-only">Filtrar termos do glossário</label>
        <input
          type="search"
          id="glossary-filter"
          placeholder="Buscar termo..."
          aria-label="Filtrar termos do glossário"
          class="glossary-input"
        />
      </search>
    </ScrollReveal>

    <div class="glossary-list" id="glossary-list">
      {glossaryTerms.map((item, index) => (
        <ScrollReveal animation="fade-up" delay={0.05 * index}>
          <GlossaryItem
            id={item.id}
            term={item.term}
            definition={item.definition}
            analogy={item.analogy}
          />
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>

<style>
  .glossary-section {
    padding: var(--space-24) 0;
    background-color: var(--color-bg-secondary);
  }

  .glossary-search {
    margin-bottom: var(--space-8);
    max-width: 24rem;
  }

  .glossary-input {
    width: 100%;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    transition: border-color var(--duration-fast) ease;
  }

  .glossary-input::placeholder {
    color: var(--color-text-muted);
  }

  .glossary-input:focus {
    outline: none;
    border-color: var(--color-border-accent);
  }

  .glossary-list {
    max-width: var(--max-width-narrow);
  }
</style>

<script>
  const filterInput = document.getElementById('glossary-filter') as HTMLInputElement;
  const glossaryList = document.getElementById('glossary-list');

  filterInput?.addEventListener('input', () => {
    const query = filterInput.value.toLowerCase().trim();
    const items = glossaryList?.querySelectorAll('.glossary-item');

    items?.forEach(item => {
      const term = item.querySelector('.glossary-term')?.textContent?.toLowerCase() || '';
      const definition = item.querySelector('.glossary-definition')?.textContent?.toLowerCase() || '';
      const matches = !query || term.includes(query) || definition.includes(query);
      (item as HTMLElement).style.display = matches ? '' : 'none';
    });
  });
</script>
