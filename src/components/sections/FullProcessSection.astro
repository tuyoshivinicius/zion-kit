const guardrailsData = [
  { icon: iconBook, title: 'Clarificação de Conformidade', description: 'Alinhamento terminológico com glossário e princípios técnicos.' },
  { icon: iconBalance, title: 'Validação de Consistência', description: 'Confronto com estado atual da Product Canon.' },
  { icon: iconSearchAlert, title: 'Validação Semântica (SBVR)', description: 'Detecção de ambiguidade, incompletude e contradição.' },
