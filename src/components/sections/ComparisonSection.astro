---
import SectionHeader from '../ui/SectionHeader.astro';
import ComparisonRow from '../ui/ComparisonRow.astro';
import ScrollReveal from '../animations/ScrollReveal.astro';

const comparisons = [
  {
    before: 'Cada funcionalidade reconstrói contexto de domínio do zero',
    after: 'A IA recebe automaticamente o contexto relevante do produto antes de trabalhar',
  },
  {
    before: 'A IA toma decisões silenciosas sobre regras de negócio',
    after: 'Toda mudança no conhecimento do produto é tornada visível e aprovada antes do código',
  },
  {
    before: 'Product owners descrevem requisitos que são traduzidos (com perda) por intermediários',
    after: 'Product owners participam diretamente — descrevem em linguagem natural, a IA formaliza',
  },
  {
    before: 'Descobertas da implementação morrem no código',
    after: 'Descobertas da implementação voltam para o repositório de conhecimento',
  },
  {
    before: 'Vocabulário inconsistente entre equipes gera bugs sutis',
    after: 'Um vocabulário oficial garante que todos usam os mesmos termos',
  },
  {
    before: 'Decisões técnicas ficam dispersas em PRs, Slack e cabeças',
    after: 'Decisões técnicas ficam registradas formalmente com justificativa',
  },
  {
    before: 'Mudanças grandes no domínio causam efeito cascata',
    after: 'Mudanças grandes são aplicadas gradualmente, sem quebrar o existente',
  },
];
---

<section id="comparacao" class="comparison-section section-odd">
  <div class="max-width-content">
    <ScrollReveal animation="fade-up">
      <SectionHeader
        sectionNumber={7}
        title='O que muda <span class="gradient-text">na prática</span>'
        depth={1}
      />
    </ScrollReveal>

    <div class="comparison-headers">
      <div class="header-problem">
        <span class="header-icon" aria-hidden="true">&#10007;</span>
        SEM ZionKit
      </div>
      <div class="header-spacer"></div>
      <div class="header-solution">
        <span class="header-icon" aria-hidden="true">&#10003;</span>
        COM ZionKit
      </div>
    </div>

    <ScrollReveal animation="stagger">
      {comparisons.map(({ before, after }) => (
        <ComparisonRow before={before} after={after} />
      ))}
    </ScrollReveal>
  </div>
</section>

<style>
  .comparison-section {
    padding: var(--space-24) 0;
    background-color: var(--color-bg-primary);
  }

  .comparison-headers {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-border-default);
  }

  .header-problem,
  .header-solution {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .header-problem {
    color: var(--color-problem);
  }

  .header-solution {
    color: var(--color-solution);
  }

  .header-icon {
    font-size: var(--text-base);
  }

  .header-spacer {
    width: 2px;
  }

  @media (max-width: 768px) {
    .comparison-headers {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .header-spacer {
      display: none;
    }
  }
</style>
