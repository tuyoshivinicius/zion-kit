---
const roles = [
  {
    name: 'Domain Builder',
    icon: '🏗️',
    build: 'Participa das sessões de descoberta e requisitos',
    specify: 'Escreve specs de funcionalidade',
    feedback: '—',
  },
  {
    name: 'Architect',
    icon: '⚙️',
    build: 'Conduz sessão técnica; aprova viabilidade',
    specify: 'Toma decisões técnicas na spec; aprova arquitetura',
    feedback: '—',
  },
  {
    name: 'Domain Expert',
    icon: '🔍',
    build: 'Aprova fidelidade do conhecimento ao domínio',
    specify: 'Aprova impactos de negócio (quando houver)',
    feedback: '—',
  },
  {
    name: 'IA',
    icon: '🤖',
    build: 'Facilita sessões, gera planos de mudança',
    specify: 'Injeta contexto, gera plano incremental, implementa código',
    feedback: 'Atualiza a Product Canon',
  },
];

const columns = [
  { key: 'build', label: 'Etapa 1 — Construir' },
  { key: 'specify', label: 'Etapa 2 — Especificar' },
  { key: 'feedback', label: 'Etapa 3 — Retroalimentar' },
];
---

<div class="roles-matrix-wrapper">
  <table class="roles-matrix" role="table" aria-label="Papéis por etapa do ZionKit">
    <thead>
      <tr>
        <th scope="col" class="col-role">Papel</th>
        {columns.map(col => (
          <th scope="col">{col.label}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {roles.map(role => (
        <tr class="role-row">
          <td class="role-name">
            <span class="role-icon" aria-hidden="true">{role.icon}</span>
            <strong>{role.name}</strong>
          </td>
          <td>{role.build}</td>
          <td>{role.specify}</td>
          <td class:list={{ 'cell-empty': role.feedback === '—' }}>
            {role.feedback}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .roles-matrix-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    position: relative;
  }

  @media (max-width: 768px) {
    .roles-matrix-wrapper {
      mask-image: linear-gradient(to right, black 0, black calc(100% - 2rem), transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 0, black calc(100% - 2rem), transparent 100%);
    }
  }

  .roles-matrix {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    min-width: 600px;
  }

  .roles-matrix th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-weight: 600;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-border-default);
  }

  .roles-matrix td {
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border-default);
    line-height: var(--leading-normal);
    vertical-align: top;
  }

  .role-row {
    transition: background var(--duration-fast) ease;
  }

  .role-row:hover {
    background: rgba(148, 163, 184, 0.04);
  }

  .role-name {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
  }

  .role-name strong {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  .role-icon {
    font-size: var(--text-lg);
  }

  .cell-empty {
    color: var(--color-text-muted);
  }

  .col-role {
    width: 160px;
  }
</style>
