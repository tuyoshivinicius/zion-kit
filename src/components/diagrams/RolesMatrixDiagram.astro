---
const roles = [
  {
    name: 'Domain Builder',
    icon: '🏗️',
    canonBuilding: 'Participa de Discovery e Specification; decide continuidade',
    specCrafting: 'Escreve spec de feature',
    canonEnrichment: '—',
    directEdit: '—',
  },
  {
    name: 'Architect',
    icon: '⚙️',
    canonBuilding: 'Conduz Technical Constitution; aprova gates',
    specCrafting: 'Decisões técnicas; aprova camada de arquitetura',
    canonEnrichment: 'Revisão assíncrona (janela de veto)',
    directEdit: 'Aprova expert-edit-plan (obrigatório)',
  },
  {
    name: 'Domain Expert',
    icon: '🔍',
    canonBuilding: 'Aprova Discovery e Specification (com anotações e hotspots)',
    specCrafting: 'Aprova camada de negócio',
    canonEnrichment: 'Revisão assíncrona (janela de veto)',
    directEdit: 'Edita e aprova expert-edit-plan (fidelidade)',
  },
  {
    name: 'IA',
    icon: '🤖',
    canonBuilding: 'Conduz sessões, gera Change Plans, opera guardrails',
    specCrafting: 'Gera Change Plan incremental; implementa código',
    canonEnrichment: 'Atualiza Product Canon',
    directEdit: 'Conduz guardrails; gera expert-edit-plan',
  },
];

const columns = [
  { key: 'canonBuilding', label: 'Etapa 1 — Canon Building' },
  { key: 'specCrafting', label: 'Etapa 2 — Spec Crafting' },
  { key: 'canonEnrichment', label: 'Etapa 3 — Canon Enrichment' },
  { key: 'directEdit', label: 'Edição Direta' },
];
---

<div class="roles-matrix-outer">
  <div class="roles-matrix-wrapper">
    <table class="roles-matrix" role="table" aria-label="Papéis por etapa do ZionKit">
      <thead>
        <tr>
          <th scope="col" class="col-role">Papel</th>
          {columns.map(col => (
            <th scope="col">{col.label}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {roles.map(role => (
          <tr class="role-row">
            <td class="role-name">
              <span class="role-icon" aria-hidden="true">{role.icon}</span>
              <strong>{role.name}</strong>
            </td>
            {columns.map(col => (
              <td class:list={{ 'cell-empty': role[col.key] === '—' }}>
                {role[col.key]}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="protocol-indicator">
    <span class="protocol-badge" aria-hidden="true">👥</span>
    <p><strong>Protocolo de Perspectiva Assistida:</strong> Quando uma pessoa acumula papéis, a IA medeia checklist de perspectiva por papel e registra cada aprovação separadamente.</p>
  </div>
</div>

<style>
  .roles-matrix-outer {
    position: relative;
  }

  .roles-matrix-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    position: relative;
  }

  @media (max-width: 768px) {
    .roles-matrix-wrapper {
      mask-image: linear-gradient(to right, black 0, black calc(100% - 2rem), transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 0, black calc(100% - 2rem), transparent 100%);
    }
  }

  @media (max-width: 480px) {
    .roles-matrix-wrapper {
      mask-image: linear-gradient(to right, black 0, black 85%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 0, black 85%, transparent 100%);
    }
  }

  .roles-matrix {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    min-width: 780px;
  }

  .roles-matrix th {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    font-weight: 600;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-bottom: 2px solid var(--color-border-default);
  }

  .roles-matrix td {
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border-default);
    line-height: var(--leading-normal);
    vertical-align: top;
  }

  .role-row {
    transition: background 0.2s ease;
  }

  .role-row:hover {
    background: rgba(34, 211, 238, 0.05);
  }

  .role-name {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
    position: sticky;
    left: 0;
    z-index: 1;
    background: var(--color-bg-surface, #0a0e17);
    box-shadow: 1px 0 0 var(--color-border-default);
  }

  .role-row:hover .role-name {
    background: #0d1220;
  }

  .role-name strong {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  .role-icon {
    font-size: var(--text-lg);
  }

  .cell-empty {
    color: var(--color-text-muted);
  }

  .col-role {
    width: 140px;
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--color-bg-surface, #0a0e17);
    box-shadow: 1px 0 0 var(--color-border-default);
  }

  .protocol-indicator {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-aurora-green);
  }

  .protocol-badge {
    font-size: var(--text-lg);
    flex-shrink: 0;
    line-height: 1.4;
  }

  .protocol-indicator p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .role-row {
      transition: none;
    }
  }
</style>
