---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="max-width-content footer-inner">
    <div class="footer-brand">
      <span class="gradient-text" style="font-size: var(--text-xl); font-weight: 700;">ZionKit</span>
      <p>Modelo conceitual para desenvolvimento de software orientado por especificações.</p>
      <p class="footer-status">Protótipo conceitual — v0.6</p>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} ZionKit. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-border-default);
    padding: var(--space-12) 0 var(--space-6);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .footer-status {
    font-style: italic;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-4);
    margin-top: var(--space-4);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
