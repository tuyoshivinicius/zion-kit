---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="max-width-content footer-inner">
    <div class="footer-brand">
      <span class="gradient-text" style="font-size: var(--text-xl); font-weight: 700;">ZionKit</span>
      <p>Modelo conceitual para desenvolvimento de software orientado por especificações.</p>
      <p class="footer-status">Protótipo conceitual — v0.6</p>
      <a
        href="https://github.com/tuyoshivinicius/zion-kit/blob/main/docs/zionkit-model.md"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-docs-link"
      >
        Documentação técnica completa &rarr;
      </a>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} ZionKit. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-border-default);
    padding: var(--space-12) 0 var(--space-6);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .footer-status {
    font-style: italic;
  }

  .footer-docs-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    min-height: 44px;
    color: var(--color-text-accent);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-docs-link:hover {
    color: var(--color-text-primary);
    text-decoration: underline;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-4);
    margin-top: var(--space-4);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
