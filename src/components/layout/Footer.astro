---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="max-width-content footer-inner">
    <div class="footer-brand">
      <span class="gradient-text" style="font-size: var(--text-xl); font-weight: 700;">ZionKit</span>
      <p>O conhecimento do seu produto, formalizado e versionado.</p>
    </div>

    <div class="footer-newsletter">
      <h3>Receba atualizações</h3>
      <form class="newsletter-form" action="#" method="post" aria-label="Inscrever-se na newsletter">
        <input
          type="email"
          name="email"
          placeholder="seu@email.com"
          required
          aria-label="Endereço de email"
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">
          Inscrever
        </button>
      </form>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} ZionKit. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-border-default);
    padding: var(--space-12) 0 var(--space-6);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .footer-newsletter h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-2);
  }

  .newsletter-input {
    flex: 1;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    min-width: 0;
  }

  .newsletter-input::placeholder {
    color: var(--color-text-muted);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-border-accent);
  }

  .newsletter-btn {
    background: var(--gradient-aurora);
    color: var(--color-bg-primary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    border: none;
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    cursor: pointer;
    white-space: nowrap;
    transition: box-shadow var(--duration-normal) ease;
  }

  .newsletter-btn:hover {
    box-shadow: var(--shadow-glow-cyan);
  }

  .footer-bottom {
    grid-column: 1 / -1;
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-4);
    margin-top: var(--space-4);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
