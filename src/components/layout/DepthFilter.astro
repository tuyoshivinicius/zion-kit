---
/**
 * DepthFilter — Toggle persistente com 3 opções de profundidade.
 * Essencial (Camada 1): Seções 1-4, 7, 9, 10
 * Detalhado (Camada 2): + Seções 5, 6
 * Técnico (Camada 3): + Seção 8
 */
const levels = [
  { id: 'essential', label: 'Essencial', time: '~5 min' },
  { id: 'detailed', label: 'Detalhado', time: '~12 min' },
  { id: 'technical', label: 'Técnico', time: '~20 min' },
];
---

<div class="depth-filter" role="group" aria-label="Filtro de profundidade de leitura">
  {levels.map((level, i) => (
    <button
      class:list={['depth-btn', { active: i === 2 }]}
      data-depth={level.id}
      aria-pressed={i === 2 ? 'true' : 'false'}
    >
      {level.label}
      <span class="depth-time">{level.time}</span>
    </button>
  ))}
</div>

<style>
  .depth-filter {
    display: flex;
    gap: var(--space-1);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-full);
    padding: 2px;
    border: 1px solid var(--color-border-default);
  }

  .depth-btn {
    background: none;
    border: none;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
    display: flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }

  .depth-btn:hover {
    color: var(--color-text-secondary);
  }

  .depth-btn.active {
    background: rgba(34, 211, 238, 0.1);
    color: var(--color-text-accent);
  }

  .depth-time {
    font-size: 0.625rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .depth-filter {
      display: none;
    }
  }
</style>

<script>
  const depthSections: Record<string, string[]> = {
    essential: ['problema', 'agitacao', 'solucao', 'ciclo', 'comparacao', 'cenarios', 'glossario'],
    detailed: ['problema', 'agitacao', 'solucao', 'ciclo', 'pilares', 'papeis', 'comparacao', 'cenarios', 'glossario'],
    technical: ['problema', 'agitacao', 'solucao', 'ciclo', 'pilares', 'papeis', 'comparacao', 'canon', 'cenarios', 'glossario'],
  };

  const allSectionIds = ['problema', 'agitacao', 'solucao', 'ciclo', 'pilares', 'papeis', 'comparacao', 'canon', 'cenarios', 'glossario'];

  function applyDepth(level: string) {
    const visible = depthSections[level] || allSectionIds;

    allSectionIds.forEach(id => {
      const section = document.getElementById(id);
      if (!section) return;

      if (visible.includes(id)) {
        section.style.display = '';
        section.removeAttribute('aria-hidden');
      } else {
        section.style.display = 'none';
        section.setAttribute('aria-hidden', 'true');
      }
    });

    sessionStorage.setItem('depth-level', level);
  }

  const buttons = document.querySelectorAll('.depth-btn');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      const level = (btn as HTMLElement).dataset.depth || 'technical';
      applyDepth(level);
    });
  });

  // Restore from session
  const saved = sessionStorage.getItem('depth-level');
  if (saved && saved !== 'technical') {
    applyDepth(saved);
    buttons.forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.depth === saved);
      btn.setAttribute('aria-pressed', String((btn as HTMLElement).dataset.depth === saved));
    });
  }
</script>
