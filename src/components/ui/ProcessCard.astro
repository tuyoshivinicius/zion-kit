---
interface Props {
  title: string;
  description: string;
  icon: string;
  roles: string[];
  type: 'ceremony' | 'decision' | 'process' | 'complementary';
  accentColor: string;
  position?: 'left' | 'right' | 'lateral';
}

const { title, description, icon, roles, type, accentColor, position = 'left' } = Astro.props;

const roleColors: Record<string, string> = {
  'Domain Builder': 'var(--color-aurora-green)',
  'Architect': 'var(--color-aurora-cyan)',
  'Domain Expert': 'var(--color-aurora-violet)',
  'IA': 'var(--color-aurora-blue)',
  'Desenvolvedor': 'var(--color-aurora-green)',
  'Guardrails': 'var(--color-aurora-pink)',
  'Todos': 'var(--color-aurora-violet)',
  'Domain Builder/Architect': 'var(--color-aurora-green)',
};

const typeLabels: Record<string, string> = {
  ceremony: 'Cerimônia',
  decision: 'Decisão',
  process: 'Processo',
  complementary: 'Canal complementar',
};
---

<div class:list={['process-card', `process-card--${position}`, `process-card--${type}`, position === 'lateral' && 'process-card--lateral']}>
  <div class="process-card__icon" style={`color: ${accentColor}`}>
    <Fragment set:html={icon} />
  </div>
  <div class="process-card__content">
    <span class="process-card__type">{typeLabels[type]}</span>
    <h4 class="process-card__title">{title}</h4>
    <p class="process-card__desc">{description}</p>
    <div class="process-card__roles">
      {roles.map((role) => (
        <span class="process-card__role" style={`--role-color: ${roleColors[role] || 'var(--color-text-muted)'}`}>
          {role}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .process-card {
    display: flex;
    gap: var(--space-4);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: border-color var(--duration-normal) ease, box-shadow var(--duration-normal) ease;
    position: relative;
  }

  .process-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-glow-cyan);
  }

  .process-card--lateral {
    border-style: dashed;
    border-color: rgba(34, 211, 238, 0.25);
  }

  .process-card--lateral:hover {
    border-color: rgba(34, 211, 238, 0.5);
  }

  .process-card--decision {
    border-color: rgba(96, 165, 250, 0.25);
  }

  .process-card--decision:hover {
    box-shadow: 0 0 20px rgba(96, 165, 250, 0.15);
  }

  .process-card__icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .process-card__content {
    flex: 1;
    min-width: 0;
  }

  .process-card__type {
    display: inline-block;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-1);
  }

  .process-card__title {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold, 600);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    line-height: var(--leading-tight);
  }

  .process-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .process-card__roles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .process-card__role {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--role-color);
    background: color-mix(in srgb, var(--role-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--role-color) 25%, transparent);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    white-space: nowrap;
  }

  @media (min-width: 1024px) {
    .process-card__icon {
      width: 80px;
      height: 80px;
    }
  }

  @media (max-width: 768px) {
    .process-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .process-card__roles {
      justify-content: center;
    }
  }
</style>
