---
interface Props {
  before: string;
  after: string;
}

const { before, after } = Astro.props;
---

<div class="comparison-row">
  <div class="comparison-cell problem">
    <span class="comparison-icon" aria-hidden="true">&#10007;</span>
    <p>{before}</p>
  </div>
  <div class="comparison-separator" aria-hidden="true"></div>
  <div class="comparison-cell solution">
    <span class="comparison-icon" aria-hidden="true">&#10003;</span>
    <p>{after}</p>
  </div>
</div>

<style>
  .comparison-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border-default);
    transition: background var(--duration-fast) ease;
  }

  .comparison-row:hover {
    background: rgba(148, 163, 184, 0.03);
  }

  .comparison-cell {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .comparison-cell p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  .comparison-icon {
    font-size: var(--text-lg);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .problem .comparison-icon {
    color: var(--color-problem);
  }

  .problem p {
    color: var(--color-text-secondary);
  }

  .solution .comparison-icon {
    color: var(--color-solution);
  }

  .solution p {
    color: var(--color-text-primary);
  }

  .comparison-separator {
    width: 2px;
    height: 100%;
    min-height: 2rem;
    background: var(--gradient-aurora);
    border-radius: var(--radius-full);
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .comparison-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .comparison-separator {
      width: 100%;
      height: 1px;
      min-height: auto;
    }
  }
</style>
