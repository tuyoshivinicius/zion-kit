---
interface Props {
  label: string;
  title?: string;
  class?: string;
}

const { label, title, class: className = '' } = Astro.props;
---

<figure
  class:list={['diagram-container', className]}
  aria-label={label}
>
  {title && <figcaption class="diagram-title">{title}</figcaption>}
  <div class="diagram-content">
    <slot />
  </div>
</figure>

<style>
  .diagram-container {
    width: 100%;
    max-width: var(--max-width-diagram);
    margin: var(--space-8) auto;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .diagram-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border-default);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .diagram-content {
    padding: var(--space-6);
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .diagram-content {
      padding: var(--space-3);
      min-height: auto;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .diagram-content :global(> astro-island > div),
    .diagram-content :global(> div) {
      min-width: 850px;
    }

    .diagram-container {
      position: relative;
    }

    .diagram-container::after {
      content: '← deslize para ver →';
      display: block;
      text-align: center;
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      padding: var(--space-2);
      opacity: 0.6;
    }
  }
</style>
