---
interface Props {
  term: string;
  definition: string;
  analogy?: string;
  id: string;
}

const { term, definition, analogy, id } = Astro.props;
---

<div class="glossary-item" id={id}>
  <button
    class="glossary-trigger"
    aria-expanded="false"
    aria-controls={`glossary-content-${id}`}
  >
    <span class="glossary-term">{term}</span>
    <span class="glossary-chevron" aria-hidden="true">&#9660;</span>
  </button>

  <div
    id={`glossary-content-${id}`}
    class="glossary-content"
    role="region"
    aria-label={`Definição de ${term}`}
  >
    <p class="glossary-definition">{definition}</p>
    {analogy && (
      <div class="glossary-analogy">
        <span class="analogy-badge">Analogia</span>
        <p>{analogy}</p>
      </div>
    )}
  </div>
</div>

<style>
  .glossary-item {
    border-bottom: 1px solid var(--color-border-default);
  }

  .glossary-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: var(--space-4) 0;
    cursor: pointer;
    text-align: left;
    gap: var(--space-4);
  }

  .glossary-term {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-accent);
  }

  .glossary-chevron {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: transform var(--duration-normal) ease;
  }

  .glossary-trigger[aria-expanded="true"] .glossary-chevron {
    transform: rotate(180deg);
  }

  .glossary-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height var(--duration-normal) ease, opacity var(--duration-normal) ease;
  }

  .glossary-content.open {
    max-height: 500px;
    opacity: 1;
  }

  .glossary-definition {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    padding-bottom: var(--space-3);
  }

  .glossary-analogy {
    padding-bottom: var(--space-4);
  }

  .analogy-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-aurora-violet);
    border: 1px solid rgba(167, 139, 250, 0.3);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-2);
    margin-bottom: var(--space-2);
  }

  .glossary-analogy p {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }
</style>

<script>
  document.querySelectorAll('.glossary-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      const contentId = trigger.getAttribute('aria-controls');
      if (!contentId) return;
      const content = document.getElementById(contentId);
      content?.classList.toggle('open');
    });
  });
</script>
