---
interface Props {
  title: string;
  description?: string;
  linkText: string;
  linkHref: string;
  external?: boolean;
}

const { title, description, linkText, linkHref, external = false } = Astro.props;
---

<div class="cta-banner">
  <div class="cta-content">
    <h3 class="cta-title">{title}</h3>
    {description && <p class="cta-desc">{description}</p>}
  </div>
  <a
    href={linkHref}
    class="cta-link"
    {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
  >
    {linkText}
    <span aria-hidden="true">&rarr;</span>
  </a>
</div>

<style>
  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    background: var(--gradient-aurora-soft);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-xl);
    padding: var(--space-6) var(--space-8);
    margin: var(--space-12) 0;
  }

  .cta-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
  }

  .cta-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--gradient-aurora);
    color: var(--color-bg-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    white-space: nowrap;
    transition: box-shadow var(--duration-normal) ease, transform var(--duration-fast) ease;
  }

  .cta-link:hover {
    box-shadow: var(--shadow-glow-cyan);
    transform: translateY(-1px);
    color: var(--color-bg-primary);
  }

  @media (max-width: 768px) {
    .cta-banner {
      flex-direction: column;
      text-align: center;
      padding: var(--space-6);
    }
  }
</style>
