---
interface Props {
  value: string;
  description: string;
  source?: string;
}

const { value, description, source } = Astro.props;
---

<div class="stat-card">
  <span class="stat-value gradient-text" data-value={value}>{value}</span>
  <p class="stat-description">{description}</p>
  {source && <span class="stat-source">{source}</span>}
</div>

<style>
  .stat-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
    transition: box-shadow var(--duration-normal) ease, border-color var(--duration-normal) ease;
  }

  .stat-card:hover {
    box-shadow: var(--shadow-glow-cyan);
    border-color: var(--color-border-accent);
  }

  .stat-value {
    font-size: var(--text-4xl);
    font-weight: 700;
    display: block;
    margin-bottom: var(--space-2);
  }

  .stat-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .stat-source {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }
</style>
