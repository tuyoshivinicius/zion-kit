---
interface Props {
  variant?: 'quote' | 'analogy';
}

const { variant = 'quote' } = Astro.props;
const icon = variant === 'analogy' ? '💡' : '❝';
---

<blockquote class:list={['example-block', variant]}>
  <span class="example-icon" aria-hidden="true">{icon}</span>
  <div class="example-content">
    <slot />
  </div>
</blockquote>

<style>
  .example-block {
    background: var(--color-bg-tertiary);
    border-left: 3px solid var(--color-aurora-cyan);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-6);
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .example-block.analogy {
    border-left-color: var(--color-aurora-violet);
  }

  .example-icon {
    font-size: var(--text-2xl);
    line-height: 1;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .example-content {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .example-content :global(strong) {
    color: var(--color-text-primary);
    font-style: normal;
  }
</style>
