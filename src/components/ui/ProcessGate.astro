---
interface Props {
  title: string;
  planType: string;
  primaryApprover: string;
  secondaryApprover: string;
  isSequential?: boolean;
}

const { title, planType, primaryApprover, secondaryApprover, isSequential = false } = Astro.props;

const approverColors: Record<string, string> = {
  'Domain Expert': 'var(--color-aurora-violet)',
  'Architect': 'var(--color-aurora-cyan)',
  'Domain Builder': 'var(--color-aurora-green)',
};
---

<div class="process-gate">
  <div class="process-gate__icon" aria-hidden="true">
    <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 4L6 14v12c0 10.5 7.8 20.3 18 22.7C34.2 46.3 42 36.5 42 26V14L24 4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M16 24l5 5 11-11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
  <div class="process-gate__content">
    <span class="process-gate__label">Gate de aprovação</span>
    <h4 class="process-gate__title">{title}</h4>
    <div class="process-gate__plan-type">
      <code>{planType}</code>
    </div>
    <div class="process-gate__approvers">
      <div class="process-gate__approver">
        <span class="process-gate__order">{isSequential ? '1º' : '●'}</span>
        <span class="process-gate__approver-name" style={`color: ${approverColors[primaryApprover] || 'var(--color-text-primary)'}`}>
          {primaryApprover}
        </span>
        <span class="process-gate__approver-role">
          {isSequential ? 'fidelidade semântica' : 'aprovação primária'}
        </span>
      </div>
      <span class="process-gate__arrow" aria-hidden="true">{isSequential ? '→' : '·'}</span>
      <div class="process-gate__approver">
        <span class="process-gate__order">{isSequential ? '2º' : '●'}</span>
        <span class="process-gate__approver-name" style={`color: ${approverColors[secondaryApprover] || 'var(--color-text-primary)'}`}>
          {secondaryApprover}
        </span>
        <span class="process-gate__approver-role">
          {isSequential ? 'impacto técnico' : 'aprovação secundária'}
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .process-gate {
    display: flex;
    gap: var(--space-4);
    background: var(--color-bg-tertiary);
    border: 2px solid var(--color-aurora-pink);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--shadow-glow-violet);
    transition: box-shadow var(--duration-normal) ease;
    position: relative;
  }

  .process-gate:hover {
    box-shadow: 0 0 30px rgba(244, 114, 182, 0.2);
  }

  .process-gate__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    color: var(--color-aurora-pink);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-gate__icon svg {
    width: 100%;
    height: 100%;
  }

  .process-gate__content {
    flex: 1;
    min-width: 0;
  }

  .process-gate__label {
    display: inline-block;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-aurora-pink);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-1);
  }

  .process-gate__title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold, 600);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .process-gate__plan-type {
    margin-bottom: var(--space-3);
  }

  .process-gate__plan-type code {
    font-size: var(--text-xs);
    background: rgba(244, 114, 182, 0.1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    color: var(--color-aurora-pink);
  }

  .process-gate__approvers {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .process-gate__approver {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .process-gate__order {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-aurora-pink);
  }

  .process-gate__approver-name {
    font-weight: 600;
  }

  .process-gate__approver-role {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .process-gate__arrow {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  @media (max-width: 768px) {
    .process-gate {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .process-gate__approvers {
      flex-direction: column;
      gap: var(--space-2);
    }

    .process-gate__approver {
      flex-direction: column;
      gap: var(--space-1);
    }

    .process-gate__arrow {
      transform: rotate(90deg);
    }
  }
</style>
