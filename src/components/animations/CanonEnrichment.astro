---
/**
 * CanonEnrichment — Fixed icon that pulses when scrolling
 * through retroalimentação sections (4, 5.3).
 */
---

<div class="canon-enrichment" id="canon-enrichment" aria-hidden="true">
  <div class="enrichment-icon">
    <span class="enrichment-emoji">📚</span>
    <span class="enrichment-counter" id="enrichment-counter">0</span>
  </div>
  <span class="enrichment-plus" id="enrichment-plus">+1</span>
</div>

<style>
  .canon-enrichment {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-elevated);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    opacity: 0.6;
    transition: opacity var(--duration-normal) ease;
  }

  .canon-enrichment:hover {
    opacity: 1;
  }

  .enrichment-icon {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-3);
    box-shadow: var(--shadow-md);
  }

  .enrichment-emoji {
    font-size: var(--text-lg);
  }

  .enrichment-counter {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-accent);
    font-family: var(--font-mono);
  }

  .enrichment-plus {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-aurora-green);
    opacity: 0;
    transform: translateY(0);
    transition: all 0.4s ease;
    pointer-events: none;
  }

  .enrichment-plus.show {
    opacity: 1;
    transform: translateY(-16px);
  }

  @media (max-width: 768px) {
    .canon-enrichment {
      bottom: var(--space-3);
      right: var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .enrichment-plus {
      transition: none;
    }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    let count = 0;
    const counter = document.getElementById('enrichment-counter');
    const plus = document.getElementById('enrichment-plus');

    const increment = () => {
      count++;
      if (counter) counter.textContent = String(count);
      if (plus) {
        plus.classList.add('show');
        setTimeout(() => plus.classList.remove('show'), 600);
      }
    };

    const init = async () => {
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      const { gsap } = await import('gsap');
      gsap.registerPlugin(ScrollTrigger);

      // Trigger on section 4 (ciclo) and section 5 pillar 3 area
      ['#ciclo', '#pilares'].forEach(selector => {
        const section = document.querySelector(selector);
        if (!section) return;

        ScrollTrigger.create({
          trigger: section,
          start: 'top 50%',
          once: true,
          onEnter: increment,
        });
      });
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => init());
    } else {
      setTimeout(init, 300);
    }
  }
</script>
