---
interface Props {
  animation?: 'fade-up' | 'fade-in' | 'slide-left' | 'slide-right' | 'scale-in' | 'stagger' | 'counter' | 'draw-line';
  delay?: number;
  tag?: string;
  class?: string;
}

const {
  animation = 'fade-up',
  delay = 0,
  tag = 'div',
  class: className = '',
} = Astro.props;

const Tag = tag as any;
---

<Tag
  class:list={['scroll-reveal', className]}
  data-animation={animation}
  data-delay={delay}
  style={`opacity: 0;`}
>
  <slot />
</Tag>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const init = async () => {
      const { gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      const elements = document.querySelectorAll('.scroll-reveal');

      elements.forEach(el => {
        const animation = el.getAttribute('data-animation') || 'fade-up';
        const delay = parseFloat(el.getAttribute('data-delay') || '0');

        const animations: Record<string, gsap.TweenVars> = {
          'fade-up': { opacity: 0, y: 30, duration: 0.6 },
          'fade-in': { opacity: 0, duration: 0.4 },
          'slide-left': { opacity: 0, x: -40, duration: 0.6 },
          'slide-right': { opacity: 0, x: 40, duration: 0.6 },
          'scale-in': { opacity: 0, scale: 0.95, duration: 0.5 },
          'stagger': { opacity: 0, y: 30, duration: 0.6 },
          'counter': { opacity: 0, duration: 0.4 },
          'draw-line': { opacity: 0, scaleX: 0, duration: 0.8, transformOrigin: 'left center' },
        };

        const from = animations[animation] || animations['fade-up'];

        if (animation === 'stagger') {
          const children = el.children;
          if (children.length > 0) {
            gsap.set(children, { opacity: 0, y: 30 });
            gsap.set(el, { opacity: 1 });
            ScrollTrigger.create({
              trigger: el,
              start: 'top 80%',
              once: true,
              invalidateOnRefresh: true,
              onEnter: () => {
                gsap.to(children, {
                  opacity: 1, y: 0, duration: 0.6,
                  stagger: 0.15, delay,
                  ease: 'power2.out',
                });
              },
            });
          }
        } else {
          gsap.set(el, from);
          ScrollTrigger.create({
            trigger: el,
            start: 'top 80%',
            once: true,
            invalidateOnRefresh: true,
            onEnter: () => {
              gsap.to(el, {
                opacity: 1, x: 0, y: 0, scale: 1, scaleX: 1,
                duration: from.duration || 0.6, delay,
                ease: 'power2.out',
              });
            },
          });
        }
      });

      // Refresh após todos os triggers serem criados
      ScrollTrigger.refresh();

      // Re-refresh quando seções com content-visibility ficam visíveis
      if ('oncontentvisibilityautostatechange' in HTMLElement.prototype) {
        document.querySelectorAll('section').forEach(section => {
          section.addEventListener('contentvisibilityautostatechange', () => {
            ScrollTrigger.refresh();
          }, { once: true });
        });
      }

      // Safety net: garante que conteúdo nunca fique invisível para sempre
      setTimeout(() => {
        document.querySelectorAll('.scroll-reveal').forEach(el => {
          if (getComputedStyle(el).opacity === '0') {
            (el as HTMLElement).style.opacity = '1';
            (el as HTMLElement).style.transform = 'none';
          }
          Array.from(el.children).forEach(child => {
            if (getComputedStyle(child).opacity === '0') {
              (child as HTMLElement).style.opacity = '1';
              (child as HTMLElement).style.transform = 'none';
            }
          });
        });
      }, 5000);
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => init());
    } else {
      setTimeout(init, 200);
    }
  } else {
    // Reduced motion: show everything immediately
    document.querySelectorAll('.scroll-reveal').forEach(el => {
      (el as HTMLElement).style.opacity = '1';
    });
  }
</script>
