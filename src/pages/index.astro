---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuroraBackground from '../components/animations/AuroraBackground.astro';
import StickyNav from '../components/layout/StickyNav.astro';
import ProgressBar from '../components/layout/ProgressBar.astro';
import CanonEnrichment from '../components/animations/CanonEnrichment.astro';
import CTABanner from '../components/ui/CTABanner.astro';
import Footer from '../components/layout/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import ConsequenciasSection from '../components/sections/ConsequenciasSection.astro';
import SolutionBridgeSection from '../components/sections/SolutionBridgeSection.astro';
import CycleOverviewSection from '../components/sections/CycleOverviewSection.astro';
import CanonBuildingSection from '../components/sections/CanonBuildingSection.astro';
import SpecCraftingSection from '../components/sections/SpecCraftingSection.astro';
import EnrichmentSection from '../components/sections/EnrichmentSection.astro';
import GuardrailsSection from '../components/sections/GuardrailsSection.astro';
import RolesSection from '../components/sections/RolesSection.astro';
import ChangePlanSection from '../components/sections/ChangePlanSection.astro';
import CanonDeepDiveSection from '../components/sections/CanonDeepDiveSection.astro';
import DirectEditSection from '../components/sections/DirectEditSection.astro';
import ComparisonSection from '../components/sections/ComparisonSection.astro';
import ScenariosSection from '../components/sections/ScenariosSection.astro';
import RiscosSection from '../components/sections/RiscosSection.astro';
import GlossarySection from '../components/sections/GlossarySection.astro';
---

<BaseLayout>
  <a href="#main-content" class="skip-link">Pular para o conteúdo</a>

  <AuroraBackground />
  <ProgressBar />
  <StickyNav />
  <CanonEnrichment />

  <main id="main-content" role="main">
    <!-- 1 — O Problema -->
    <HeroSection />

    <!-- 2 — Consequências -->
    <ConsequenciasSection />

    <!-- 3 — A Solução -->
    <SolutionBridgeSection />

    <!-- 4 — Visão Geral do Ciclo -->
    <CycleOverviewSection />

    <!-- 5 — Canon Building -->
    <CanonBuildingSection />

    <!-- 6 — Spec Crafting -->
    <SpecCraftingSection />

    <!-- 7 — Enrichment -->
    <EnrichmentSection />

    <!-- 8 — Guardrails -->
    <GuardrailsSection />

    <!-- 9 — Papéis -->
    <RolesSection />

    <!-- 10 — Canonical Change Plan -->
    <ChangePlanSection />

    <!-- 11 — Product Canon Deep Dive -->
    <CanonDeepDiveSection />

    <!-- 12 — Edição Direta -->
    <DirectEditSection />

    <!-- 13 — Antes/Depois -->
    <ComparisonSection />

    <!-- 14 — Cenários -->
    <ScenariosSection />

    <!-- CTA nota informativa -->
    <div class="max-width-content">
      <CTABanner
        title="Quer reler desde o início?"
        description="O ZionKit é um modelo conceitual em fase de prototipação. A leitura completa leva cerca de 15 minutos."
        linkText="Reler desde o início"
        linkHref="#problema"
      />
    </div>

    <!-- 15 — Riscos -->
    <RiscosSection />

    <!-- 16 — Glossário -->
    <GlossarySection />

    <!-- CTA — Documentação técnica -->
    <div class="max-width-content">
      <CTABanner
        title="Leia a documentação técnica completa"
        description="Acesse a especificação formal do modelo ZionKit — ciclos, cerimônias, artefatos e regras detalhadas."
        linkText="Ver documentação"
        linkHref="https://github.com/tuyoshivinicius/zion-kit/blob/main/docs/zionkit-model.md"
        external
      />
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: calc(var(--z-overlay) + 1);
    background: var(--color-bg-elevated);
    color: var(--color-text-accent);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: top var(--duration-fast) ease;
  }

  .skip-link:focus {
    top: var(--space-4);
  }
</style>
